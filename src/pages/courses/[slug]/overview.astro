---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { courseRegistry } from '../../../courses/registry';

export function getStaticPaths() {
  return courseRegistry
    .filter((course) => course.status === 'live')
    .map((course) => ({
      params: {
        slug: course.slug,
      },
    }));
}

const { slug } = Astro.params;
const locale = 'ko';
const destination = `/courses/${slug}/guide`;
---

<BaseLayout description="Redirecting to the lecture guide." locale={locale} noindex={true} path={destination} title="Redirecting...">
  <script is:inline define:vars={{ destination }}>
    window.location.replace(destination);
  </script>
  <main style="min-height: 100vh; display: grid; place-items: center; padding: 2rem; color: #e2e8f0; background: #020617;">
    <a href={destination} style="color: #67e8f9;">상세강의자료로 이동</a>
  </main>
</BaseLayout>
