---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { courseRegistry } from '../../../../courses/registry';

export function getStaticPaths() {
  return courseRegistry
    .filter((course) => course.status === 'live')
    .map((course) => ({
      params: {
        slug: course.slug,
      },
    }));
}

const { slug } = Astro.params;
const locale = 'en';
const destination = `/en/courses/${slug}/guide`;
---

<BaseLayout description="Redirecting to the lecture guide." locale={locale} noindex={true} path={destination} title="Redirecting...">
  <script is:inline>{`window.location.replace(${JSON.stringify(destination)});`}</script>
  <main style="min-height: 100vh; display: grid; place-items: center; padding: 2rem; color: #e2e8f0; background: #020617;">
    <a href={destination} style="color: #67e8f9;">Continue to the Lecture Guide</a>
  </main>
</BaseLayout>
